{
    "lldb.consoleMode": "commands",
    "lldb.dereferencePointers": true,
    "lldb.displayFormat": "auto",
    "lldb.showDisassembly": "auto",
    "rust-analyzer.cargo.buildScripts.enable": true,
    "rust-analyzer.cargo.extraEnv": {
        "FFMPEG_INCLUDE_DIR": "${userHome}/Workspace/vcpkg/installed/x64-windows-static/include",
        "FFMPEG_LIBS_DIR": "${userHome}/Workspace/vcpkg/installed/x64-windows-static/lib",
        "RUST_BACKTRACE": "1",
        "RUSTFLAGS": "-Ctarget-feature=+crt-static",
    },
    "rust-analyzer.inlayHints.parameterHints.enable": true,
    "rust-analyzer.inlayHints.typeHints.enable": true,
    "rust-analyzer.procMacro.enable": true,
    "rust-analyzer.showUnlinkedFileNotification": false,
    "rust-analyzer.trace.server": "verbose",
    "cSpell.words": [
        "AUDCLNT",
        "avcodec",
        "avdevice",
        "AVERROR",
        "avfilter",
        "AVFMT",
        "avformat",
        "avio",
        "BGRA",
        "Borderless",
        "CLSCTX",
        "codecpar",
        "COINIT",
        "Ctarget",
        "Dxgi",
        "EAGAIN",
        "FLTP",
        "GLOBALHEADER",
        "hmoniros",
        "HMONITOR",
        "hmonitors",
        "IDXGI",
        "Inspectable",
        "libx",
        "linesize",
        "lprect",
        "mfuuid",
        "nanos",
        "NOFILE",
        "nonoverlapping",
        "NOPTS",
        "nvcodec",
        "oformat",
        "PKEY",
        "PWSTR",
        "pwsz",
        "resampler",
        "rustc",
        "RUSTFLAGS",
        "SHAREMODE",
        "STGM",
        "STREAMFLAGS",
        "strmiids",
        "SUBRESOURCE",
        "swresample",
        "swscale",
        "ultrafast",
        "unref",
        "USERPROFILE",
        "vcpkg",
        "veryfast",
        "WAVEFORMATEX",
        "zerolatency"
    ]
}