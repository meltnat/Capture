{
    // IntelliSense を使用して利用可能な属性を学べます。
    // 既存の属性の説明をホバーして表示します。
    // 詳細情報は次を確認してください: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug executable 'Capture'",
            "cargo": {
                "args": [
                    "build",
                    "--bin=Capture",
                    "--package=Capture"
                ],
                "filter": {
                    "name": "Capture",
                    "kind": "bin"
                }
            },
            "env": {
                "RUST_BACKTRACE": "1",
                "RUSTFLAGS": "-Ctarget-feature=+crt-static",
                "FFMPEG_LIBS_DIR": "${userHome}/Workspace/vcpkg/installed/x64-windows-static-md/lib",
                "FFMPEG_INCLUDE_DIR": "${userHome}/Workspace/vcpkg/installed/x64-windows-static-md/include"
            },
            "args": [
                "-a",
                "-m",
                "-d",
                "--video-encoder",
                "h264_nvenc",
                "-u",
                "rtmp://localhost/live/test"
            ],
            "cwd": "${workspaceFolder}"
        }
    ]
}